ERP_READ_MODE=mock
ERP_WRITE_MODE=mock

# Use sap_sandbox when you have Business Accelerator Hub credentials.
SAP_API_BASE_URL=https://sandbox.api.sap.com/s4hanacloud
SAP_API_KEY=replace-with-local-secret

MOCK_ERP_BASE_URL=http://localhost:4010
PORT=4004
